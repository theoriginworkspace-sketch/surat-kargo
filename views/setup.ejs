<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sürat Kargo — Kurulum</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #f5f5f5;
      color: #1a1a1a;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .card {
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 12px;
      padding: 40px;
      max-width: 480px;
      width: 90%;
    }
    h1 { font-size: 22px; margin-bottom: 8px; }
    .subtitle { color: #666; font-size: 14px; margin-bottom: 32px; }
    .step {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 20px;
    }
    .step-num {
      background: #2563eb;
      color: #fff;
      width: 28px;
      height: 28px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 600;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .step-num.done { background: #16a34a; }
    .step-content { flex: 1; }
    .step-title { font-weight: 600; font-size: 15px; margin-bottom: 4px; }
    .step-desc { font-size: 13px; color: #666; line-height: 1.5; }
    .status { font-size: 13px; margin-top: 4px; }
    .status.ok { color: #16a34a; }
    .status.pending { color: #d97706; }
    .connect-btn {
      display: block;
      width: 100%;
      padding: 14px;
      background: #2563eb;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 600;
      cursor: pointer;
      margin-top: 24px;
      text-align: center;
      text-decoration: none;
    }
    .connect-btn:hover { background: #1d4ed8; }
    .connect-btn:disabled, .connect-btn.disabled {
      background: #94a3b8;
      cursor: not-allowed;
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>📦 Sürat Kargo Kurulum</h1>
    <p class="subtitle">Best Model mağazası için kargo entegrasyonu</p>

    <div class="step">
      <div class="step-num <%= suratSet ? 'done' : '' %>">1</div>
      <div class="step-content">
        <div class="step-title">Sürat Kargo API Bilgileri</div>
        <div class="step-desc">Railway Variables'a girilmiş olmalı</div>
        <div class="status <%= suratSet ? 'ok' : 'pending' %>">
          <%= suratSet ? '✓ Ayarlandı' : '⚠ Railway Variables\'dan girin' %>
        </div>
      </div>
    </div>

    <div class="step">
      <div class="step-num <%= apiKeySet ? 'done' : '' %>">2</div>
      <div class="step-content">
        <div class="step-title">Shopify API Key & Secret</div>
        <div class="step-desc">Railway Variables'a SHOPIFY_API_KEY ve SHOPIFY_API_SECRET girilmiş olmalı</div>
        <div class="status <%= apiKeySet ? 'ok' : 'pending' %>">
          <%= apiKeySet ? '✓ Ayarlandı' : '⚠ Railway Variables\'dan girin' %>
        </div>
      </div>
    </div>

    <div class="step">
      <div class="step-num">3</div>
      <div class="step-content">
        <div class="step-title">Shopify Mağaza Bağlantısı</div>
        <div class="step-desc">Aşağıdaki butona tıklayın, Shopify izin sayfası açılacak, onaylayın.</div>
      </div>
    </div>

    <% if (apiKeySet && suratSet) { %>
      <a href="https://<%= host %>/auth" target="_top" class="connect-btn">Shopify'a Bağlan</a>
    <% } else { %>
      <a class="connect-btn disabled">Önce Railway Variables'ı tamamlayın</a>
    <% } %>
  </div>
</body>
</html>
